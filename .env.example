# LLM Provider: "cerebras" (default), "ollama", "anthropic", or "openai"
LLM_PROVIDER=cerebras

# Cerebras (free tier, open-source Llama, ultra-fast cloud inference)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# Ollama (local, free, fully offline — install: brew install ollama)
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic (optional)
# ANTHROPIC_API_KEY=your_key

# OpenAI (optional)
# OPENAI_API_KEY=your_key
